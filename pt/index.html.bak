<script>
function toggleAP(r){r.classList.toggle('open')}
function copyCode(){var code=document.querySelector('.verify-code code').textContent;navigator.clipboard.writeText(code);var btn=document.querySelector('.copy-btn');btn.textContent='Copiado';setTimeout(function(){btn.textContent='Copiar'},2000)}
function togglePart(h){h.nextElementSibling.classList.toggle('collapsed')}
function scrollToAP(id){var el=document.getElementById(id);if(!el)return;var list=el.closest('.ap-list');if(list&&list.classList.contains('collapsed'))list.classList.remove('collapsed');el.classList.add('open');setTimeout(function(){var y=el.getBoundingClientRect().top+window.pageYOffset-80;window.scrollTo({top:y,behavior:'smooth'})},100)}

// Download counter
(function(){
  var counter='/../.netlify/functions/download-counter';
  var el=document.getElementById('dl-count');

  fetch(counter).then(function(r){return r.json()}).then(function(d){
    el.textContent=d.count.toLocaleString();
  }).catch(function(){el.textContent='0'});

  var toast=document.createElement('div');
  toast.className='toast';
  toast.textContent='Em breve';
  document.body.appendChild(toast);
  var toastTimer;

  document.addEventListener('click',function(e){
    var a=e.target.closest('a[href$=".pdf"]');
    if(!a) a=e.target.closest('.ap-meta a, .dl-list a');
    if(!a) return;
    var href=a.getAttribute('href');
    if(!href||href==='#'){
      e.preventDefault();
      e.stopPropagation();
      toast.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer=setTimeout(function(){toast.classList.remove('show')},2000);
      return;
    }
    // Force immediate download
    if(!a.hasAttribute('download')) a.setAttribute('download','');
    // Increment counter
    fetch(counter,{method:'POST'}).then(function(r){return r.json()}).then(function(d){
      el.textContent=d.count.toLocaleString();
    });
  },true);
})();
</script><div class="toast">Em breve</div>

