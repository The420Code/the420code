.lang-sel a{text-decoration:none;opacity:.5;transition:opacity .15s;line-height:1}
.lang-sel a:hover{opacity:1}
.lang-sel a.active{opacity:1}
.ap-header .ap-pdf{font-size:16px;font-weight:700;color:var(--g4);margin-left:6px;text-decoration:none;letter-spacing:.03em}.ap-header .ap-pdf:hover{color:var(--bk);text-decoration:underline}</style>
