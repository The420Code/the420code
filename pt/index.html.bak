<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bk:#111;--wh:#fff;--g1:#f3f3ed;--g2:#e8e8e8;--g3:#d5d5d0;--g4:#595959;--g5:#595959;--g6:#1a1a1a;--f:'Atkinson Hyperlegible',sans-serif;--mw:760px}
body{font-family:var(--f);font-size:16px;line-height:1.65;color:#1a1a1a;background:var(--wh);-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
.c{max-width:var(--mw);margin:0 auto;padding:3rem 1.5rem 4rem}
a{color:var(--bk);text-decoration:underline;text-underline-offset:2px}
a:hover{text-decoration-thickness:2px}

.nav{position:sticky;top:0;background:rgba(255,255,255,0.95);backdrop-filter:blur(8px);z-index:100;display:flex;flex-wrap:wrap;gap:1.5rem;align-items:center;padding:.7rem 0;border-bottom:1px solid var(--g3);margin:0 0 3rem}
.nav-title{font-size:16px;font-weight:400;letter-spacing:.08em;text-transform:lowercase;margin-right:auto;text-decoration:none}
.nav a:not(.nav-title){font-size:16px;color:var(--g5);text-decoration:none}
.nav a:not(.nav-title):hover{color:var(--bk);text-decoration:underline}

.section-label{font-size:16px;font-weight:700;letter-spacing:.06em;color:var(--g4);margin:0 0 .75rem;padding:4rem 0 0}

.hero{margin:2rem 0 3rem}
.hero h1{font-size:36px;font-weight:700;line-height:1.15;margin:0 0 2.5rem}
.hero .lead{font-size:18px;font-style:italic;margin:0 0 .5rem}

.steps{margin:1.5rem 0 2rem;padding:0;counter-reset:step}
.steps li{list-style:none;padding:0 0 0 2rem;position:relative;margin:0 0 .35rem;font-size:16px}
.steps li::before{counter-increment:step;content:counter(step)".";position:absolute;left:0;font-weight:700;color:var(--g4);font-size:16px}

.doors{margin:2rem 0 0;padding:2rem 0}
.doors h2{font-size:26px;font-weight:700;margin:0 0 .25rem}
.doors .sub{font-size:16px;color:var(--g5);margin:0 0 2.5rem}
.door{margin:0 0 3.5rem}
.door h3{font-size:18px;font-weight:700;margin:0 0 .15rem}
.door h3 a{text-decoration:none}
.door h3 a:hover{text-decoration:underline}
.door p{font-size:16px;color:var(--g6);margin:0 0 .25rem}
.door .hint{font-size:16px;color:var(--g4);font-style:italic}
.voices{margin:.75rem 0 0}
.voice{margin:0 0 .4rem}
.voice b{font-size:16px}
.voice span{font-size:16px;color:var(--g5)}

.read-block{margin:0 0 1.5rem;padding:2rem;border:1px solid var(--g2);background:var(--g1)}
.read-block p{font-size:16px;font-style:italic;color:var(--g5);margin:0}

.cat-section{margin:0 0 3.5rem}
.cat-title{font-size:18px;font-weight:700;margin:0 0 .75rem}
.cat-desc{font-size:16px;color:var(--g5);margin:0 0 1rem}
.cat-hint{font-size:16px;font-style:italic;color:var(--g4);margin:0 0 .75rem}
.dl-list{margin:0;padding:0 0 0 32px}
.dl-list li{list-style:none;padding:.4rem 0;border-bottom:1px solid var(--g1);font-size:16px}
.dl-list li:last-child{border-bottom:none}
.dl-list a{text-decoration:none;display:flex;justify-content:space-between;align-items:center;color:var(--bk);font-weight:600}
.dl-list a:hover{text-decoration:underline}
.dl-list .fmt{font-size:16px;font-weight:700;color:var(--g4);flex-shrink:0;margin-left:.5rem}

.spine{position:relative;padding-left:32px}
.spine::before{content:'';position:absolute;left:7px;top:0;bottom:0;width:1px;background:var(--bk)}
.part{position:relative;margin:0 0 2.5rem}
.part-dot{position:absolute;left:-32px;top:5px;width:15px;height:15px;border-radius:50%;background:var(--bk);z-index:1}
.part-header{cursor:pointer;user-select:none;padding:0 0 .5rem}
.part-header:hover .part-name{text-decoration:underline}
.part-num{font-size:16px;font-weight:700;letter-spacing:.06em;color:#757575;display:block;margin:0 0 1rem}
.part-name{font-size:22px;font-weight:700;display:block;line-height:1.2}
.part-desc{font-size:16px;color:var(--g5);font-style:italic;display:block;margin:1rem 0 0}
.part-count{font-size:16px;color:#757575;margin:4px 0 0;display:block}
.part-read{display:inline-block;margin-top:.5rem;font-size:13px;font-weight:700;letter-spacing:.06em;color:var(--bk);text-decoration:none;border-bottom:1px solid var(--bk)}
.part-read:hover{text-decoration:none;border-bottom-width:2px}
.ap-list{margin:.75rem 0 0;overflow:hidden;transition:max-height .4s ease}
.ap-list.collapsed{max-height:0!important;margin:0}
.ap-row{border-top:1px solid var(--g2)}
.ap-row:last-child{border-bottom:1px solid var(--g2)}
.ap-header{display:flex;align-items:baseline;gap:.75rem;padding:.6rem 0;cursor:pointer;user-select:none;transition:background .1s}
.ap-header:hover{background:var(--g1);margin:0 -.5rem;padding-left:.5rem;padding-right:.5rem}
.ap-number{font-size:16px;font-weight:700;color:#757575;min-width:32px;flex-shrink:0}
.ap-title{font-size:16px;font-weight:700;flex:1}
.ap-tag{font-size:16px;color:var(--g5);border:1px solid var(--g2);padding:1px 8px;border-radius:2px;white-space:nowrap;flex-shrink:0}
.ap-arrow{font-size:16px;color:var(--g4);transition:transform .2s;flex-shrink:0}
.ap-row.open .ap-arrow{transform:rotate(90deg)}
.ap-detail{display:none;padding:0 0 1rem;padding-left:32px}
.ap-row.open .ap-detail{display:block}
.ap-detail p{font-size:16px;line-height:1.6;margin:0 0 .5rem;color:var(--g6)}
.ap-detail .ap-essay{margin-top:1.5rem}
.ap-detail .ap-essay p{margin:0 0 1rem;line-height:1.75}
.ap-detail .ap-essay .sub{font-weight:700}
.ap-detail .ap-essay .ks{background:var(--g1);border-left:3px solid #8B6914;padding:16px 20px;margin:24px 0;font-size:15px;color:#3a3a3a;line-height:1.6}
.ap-detail .ap-essay .breath{text-align:center;font-style:italic;color:var(--g5);padding:40px 0;font-size:17px;margin:0}
.ap-detail .ap-essay .bc{display:inline-block;font-size:11px;letter-spacing:1px;padding:3px 8px;border-radius:3px;margin-right:4px;background:var(--g2);color:var(--g6)}
.ap-detail .ap-essay .bl{display:inline-block;font-size:11px;letter-spacing:1px;padding:3px 8px;border-radius:3px;margin-right:4px;background:var(--g2);color:var(--g6)}
.ap-meta{font-size:16px;color:var(--g4);display:flex;flex-wrap:wrap;gap:1rem;margin:.25rem 0 0}
.ap-meta a{color:#383838}

.stats{display:flex;flex-wrap:wrap;gap:2rem;margin:0 0 2rem}
.stat-num{font-size:36px;font-weight:700;line-height:1;display:block}
.stat-label{font-size:16px;color:var(--g5);display:block;margin-top:2px}

.entry-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.75rem;margin:0 0 2rem}
.entry-card{border:1px solid var(--bk);padding:.55rem 1rem;cursor:pointer;transition:background .15s,color .15s;text-decoration:none;display:block;position:relative}
.entry-card:hover{background:var(--bk);color:var(--wh)}
.entry-card-label{font-size:16px;font-weight:700;display:block;margin:0 0 2px}
.entry-card-desc{font-size:16px;display:block;opacity:.7}
.jump-card{position:relative}
.jump-card .entry-card-label{font-size:12px;font-weight:700;color:#757575;position:absolute;bottom:4px;right:8px;margin:0}
.jump-card .entry-card-desc{font-size:16px;font-weight:700;display:block;opacity:1}

.physics{margin:2.5rem 0 0;padding:2.5rem 0}
.physics h2{font-size:26px;font-weight:700;margin:0 0 1.5rem}
.physics-intro{font-size:18px;font-weight:700;margin:0 0 .5rem}
.physics-sub{font-size:16px;color:var(--g5);margin:0 0 2rem}
.physics-grid{display:grid;grid-template-columns:1fr;gap:0;margin:0 0 2rem}
.physics-card{display:flex;align-items:baseline;justify-content:space-between;padding:.6rem 0;border-bottom:1px solid var(--g1);gap:1rem}
.physics-card:last-child{border-bottom:none}
.p-name{font-size:16px;font-weight:700;flex:1}
.p-error{font-size:22px;font-weight:700;white-space:nowrap}
.p-detail{font-size:14px;color:var(--g5);margin:2px 0 0}
.p-source{font-size:13px;color:var(--g4)}
.formula{font-size:16px;margin:0 0 .75rem;padding:.5rem 0;font-style:italic;color:var(--g6)}
.three-constants{font-size:16px;font-weight:700;margin:1.5rem 0;padding:1rem 0;border-top:1px solid var(--g2);border-bottom:1px solid var(--g2)}
.also-derived{margin:1.5rem 0}
.also-derived p{font-size:16px;font-weight:700;margin:0 0 .5rem}
.also-derived ul{list-style:none;padding:0}
.also-derived li{font-size:16px;color:var(--g6);padding:.2rem 0 .2rem 1rem;position:relative}
.also-derived li::before{content:"·";position:absolute;left:0;font-weight:700}
.confirm-link{margin:2rem 0 0;font-size:18px}
.confirm-link a{font-weight:700;text-underline-offset:3px}
@media(max-width:600px){.physics-card{flex-wrap:wrap;gap:.25rem}.p-error{font-size:18px}}
.verify-wrap{position:relative;margin:1.5rem 0 0}
.verify-code{background:var(--g1);border:1px solid var(--g2);padding:1.25rem;overflow-x:auto;overflow-y:auto;max-height:200px;font-size:13px;line-height:1.55;font-family:'Courier New',Courier,monospace;white-space:pre;tab-size:4;color:var(--bk)}
.copy-btn{position:absolute;top:8px;right:8px;padding:5px 14px;font-family:var(--f);font-size:12px;font-weight:700;letter-spacing:.04em;background:var(--bk);color:var(--wh);border:none;cursor:pointer}
.copy-btn:hover{opacity:.8}
.verify-table{width:100%;border-collapse:collapse;margin:1.5rem 0 0;font-size:14px}
.verify-table th{text-align:left;font-weight:700;padding:.5rem .5rem;border-bottom:2px solid var(--bk);font-size:13px;letter-spacing:.04em;color:var(--g5)}
.verify-table td{padding:.4rem .5rem;border-bottom:1px solid var(--g1)}
.verify-table td:last-child{color:var(--g5)}
.results{margin:0;padding:2rem 0}
.results-title{font-size:16px;font-weight:700;letter-spacing:.06em;margin:0 0 1.25rem}
.result-row{display:flex;justify-content:space-between;align-items:baseline;padding:.35rem 0;font-size:16px;border-bottom:1px solid var(--g1)}
.result-row:last-child{border-bottom:none}
.result-label{color:var(--g5)}
.result-value{font-weight:700;text-align:right}

.constraint{margin:2rem 0;padding:1.5rem 0}
.constraint p{font-size:16px;margin:0 0 .25rem}

.footer{margin:3rem 0 0;padding:2rem 0 0;font-size:16px;color:var(--g4)}
.footer p{margin:0 0 .25rem}
.toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);background:var(--bk);color:var(--wh);padding:10px 24px;font-family:var(--f);font-size:16px;font-weight:700;z-index:9999;opacity:0;transition:opacity .3s}
.toast.show{opacity:1}

@media(max-width:600px){
  .c{padding:2rem 1rem 3rem}
  .hero h1{font-size:28px}
  .stats{gap:1.5rem}
  .stat-num{font-size:28px}
  .ap-header{flex-wrap:wrap;gap:.25rem .5rem}
  .ap-tag{order:3;margin-left:32px}
  .entry-grid{grid-template-columns:1fr 1fr}
  .nav{gap:.75rem;padding:.75rem 0}
}
/* Brevo overrides */
.sib-form,.sib-form *{font-family:'Atkinson Hyperlegible',sans-serif!important;color:var(--bk)!important;background:transparent!important;border-radius:0!important}
.sib-form .entry__field input{border:1px solid var(--bk)!important;padding:10px 12px!important;font-size:16px!important}
.sib-form .sib-form-block__button{background:var(--bk)!important;color:var(--wh)!important;padding:10px 24px!important;font-size:13px!important;font-weight:700!important;letter-spacing:.06em!important;border:none!important}
.sib-form .sib-form-block__button:hover{opacity:.85}
[id*="sib-container"]{padding:0!important;background:transparent!important}
.sib-form__declaration,.sib-form .entry__label,a[href*="brevo"],a[href*="sendinblue"]{display:none!important}
.pdf-pending,.pdf-pending *{opacity:.5!important;cursor:default;pointer-events:none}
</style>
<style id="claude-agent-animation-styles">
      @keyframes claude-pulse {
